{
  "name": "zen-mcp-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Model Context Protocol server that lets any MCP-compatible AI agent (Claude, ChatGPT, etc.) drive Zen by calling its HTTP API on behalf of the authenticated user.",
  "bin": {
    "zen-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
